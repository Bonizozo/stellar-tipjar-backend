DATABASE_URL=postgres://postgres:password@localhost/tipjar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PORT=8000

# CORS — comma-separated list of allowed origins.
# Leave unset (or empty) to allow all origins (no credentials).
# When set, credentials are automatically enabled.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Preflight cache duration in seconds (default: 3600)
# CORS_MAX_AGE_SECS=3600
